          "include_sqlite": {
            "default": true,
            "type": "boolean"
          },
          "output_dir": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "source_list_ids": {
            "default": [],
            "items": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "type": "array"
          }
        },
        "title": "AudienceHygieneExportRequest",
        "type": "object"
      },
      "name": "interspire_audience_hygiene_export"
    },
